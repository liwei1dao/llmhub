# Copy to .env.prod (typically /opt/llmhub-prod/.env) and fill in.
# 镜像 tag 必须是固定 semver；外部依赖通过 1panel-network 上的运维实例提供。

REGISTRY_URL=gitea.ideapsound.com
IMAGE_TAG=0.1.0

# Postgres
LLMHUB_DB_DSN=postgres://USER:PASS@postgres:5432/llmhub?sslmode=disable

# Redis
LLMHUB_REDIS_ADDR=redis:6379
LLMHUB_REDIS_PASSWORD=
LLMHUB_REDIS_DB=0

# NATS
LLMHUB_NATS_URL=nats://nats:4222

# Vault
LLMHUB_VAULT_ADDR=http://vault:8200
LLMHUB_VAULT_TOKEN=
LLMHUB_VAULT_MOUNT_PATH=secret/pool

# Shared tokens
LLMHUB_ADMIN_TOKEN=
LLMHUB_INTERNAL_TOKEN=

# 首位管理员账号（admins 表为空时由 api 启动自动注入；非空表会跳过）
# 严禁使用弱口令；首次部署后建议从 .env.prod 清掉 PASSWORD，仅保留代码侧的兜底逻辑。
LLMHUB_ADMIN_BOOTSTRAP_ACCOUNT=
LLMHUB_ADMIN_BOOTSTRAP_PASSWORD=
LLMHUB_ADMIN_BOOTSTRAP_NAME=

# 允许的 web 跨域来源（多个用英文逗号分隔），同源部署可留空
LLMHUB_WEB_ORIGINS=

# 前端注入的 API 基址
PUBLIC_API_BASE=https://api.llmhub.io
