# Copy to .env.local and fill in. 这份 env 描述的是宿主机上已经在跑的
# postgres / redis / nats / vault 的连接信息 —— compose 不会自己拉起它们。
# 容器之间走 1panel-network，所以 host 应该是宿主机上对应容器在该网络里的名字。

LLMHUB_ENV=local

# Postgres
LLMHUB_DB_DSN=postgres://llmhub:llmhub@postgres:5432/llmhub?sslmode=disable

# Redis
LLMHUB_REDIS_ADDR=redis:6379
LLMHUB_REDIS_PASSWORD=
LLMHUB_REDIS_DB=0

# NATS
LLMHUB_NATS_URL=nats://nats:4222

# Vault
LLMHUB_VAULT_ADDR=http://vault:8200
LLMHUB_VAULT_TOKEN=2520a4643edb8ebb632c5297ec4e0771
LLMHUB_VAULT_MOUNT_PATH=secret/pool

# Shared tokens
LLMHUB_ADMIN_TOKEN=8f3a2c9b1e7d4f6a5b8c2d9e1f3a4b5c6d7e8f9a0b1c2d3e4f5a6b7c8d9e0f1a
LLMHUB_INTERNAL_TOKEN=a1b2c3d4e5f6789012345678abcdef9876543210fedcba0123456789abcdef01

# 首位管理员账号（admins 表为空时由 api 启动自动注入；非空表会跳过）
LLMHUB_ADMIN_BOOTSTRAP_ACCOUNT=admin
LLMHUB_ADMIN_BOOTSTRAP_PASSWORD=admin123
LLMHUB_ADMIN_BOOTSTRAP_NAME=Local Admin

# 允许的 web 跨域来源（多个用英文逗号分隔）
LLMHUB_WEB_ORIGINS=http://localhost:13000,http://localhost:13001

# 前端注入的 API 基址。注意：Next.js 把 NEXT_PUBLIC_* 在 build 时烧进
# bundle，运行时改不了 —— 改了这里之后必须重 build web/admin 镜像，
# 并通过 docker build --build-arg NEXT_PUBLIC_API_BASE=... 传进去。
NEXT_PUBLIC_API_BASE=http://localhost:18080

# 出站邮件 (邮箱验证码)。Gmail 用 App Password 而非账号密码。
# 全部留空 → api 自动降级到 dev mailer，验证码只写日志不发邮件。
LLMHUB_SMTP_HOST=smtp.gmail.com
LLMHUB_SMTP_PORT=587
LLMHUB_SMTP_USERNAME=
LLMHUB_SMTP_PASSWORD=
LLMHUB_SMTP_FROM=
LLMHUB_SMTP_FROM_NAME=LLMHub
