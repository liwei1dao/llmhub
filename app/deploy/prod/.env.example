# Prod environment .env template — 部署到 ${PROD_DEPLOY_DIR}/.env
#
# CI 每次部署会把本文件覆盖为 .env.example（仅作参考），但**不会**
# 触碰你已经填好的 .env。新增字段时，运维需对照 .env.example 把新
# 字段补到 .env 里再 `docker compose up -d`。

# ---------- 镜像 ----------
REGISTRY_URL=gitea.ideapsound.com
# IMAGE_TAG 在 Prod Deploy 工作流里由 inputs.version 注入到 ssh
# 环境，因此 .env 里也要保持同步以便 `docker compose pull` 手动复现
IMAGE_TAG=0.1.0

# ---------- 外部依赖（生产实例 / 云数据库） ----------
LLMHUB_DB_DSN=postgres://llmhub:CHANGE_ME@pg.prod.example.com:5432/llmhub?sslmode=require
LLMHUB_REDIS_ADDR=redis.prod.example.com:6379
LLMHUB_NATS_URL=nats://nats.prod.example.com:4222

# ---------- 业务 token（首次部署生成强随机值，保管好） ----------
LLMHUB_ADMIN_TOKEN=CHANGE_ME_random_32_chars
LLMHUB_INTERNAL_TOKEN=CHANGE_ME_random_32_chars

# ---------- CORS / 前端 ----------
LLMHUB_WEB_ORIGINS=https://console.llmhub.io,https://admin.llmhub.io
PUBLIC_API_BASE=https://api.llmhub.io
