# Dev environment .env template — 部署到 ${DEV_DEPLOY_DIR}/.env
#
# CI 每次部署会把本文件覆盖为 .env.example（仅作参考），但**不会**
# 触碰你已经填好的 .env。新增字段时，运维需对照 .env.example 把新
# 字段补到 .env 里再 `docker compose up -d`。

# ---------- 镜像 ----------
REGISTRY_URL=gitea.ideapsound.com
IMAGE_TAG=dev-latest

# ---------- 外部依赖（已运维的实例） ----------
LLMHUB_DB_DSN=postgres://llmhub:CHANGE_ME@pg.example.com:5432/llmhub_dev?sslmode=disable
LLMHUB_REDIS_ADDR=redis.example.com:6379
LLMHUB_NATS_URL=nats://nats.example.com:4222

# ---------- 业务 token（首次部署生成强随机值） ----------
LLMHUB_ADMIN_TOKEN=CHANGE_ME_random_32_chars
LLMHUB_INTERNAL_TOKEN=CHANGE_ME_random_32_chars

# ---------- CORS / 前端 ----------
LLMHUB_WEB_ORIGINS=http://dev.llmhub.local,http://localhost:3001
PUBLIC_API_BASE=http://dev.llmhub.local:8081
